# ── Obsidian Mail — environment variables ──────────────────────────────────
# Copy this file to .env and fill in the values.

# URL where the frontend is served (used for CORS)
FRONTEND_URL=http://localhost

# Name of the docker-mailserver container on this host
MAILSERVER_CONTAINER=mailserver

# Zitadel OIDC issuer URL
ZITADEL_ISSUER=https://auth.link.com

# Zitadel role/group required to access Obsidian Mail
REQUIRED_GROUP=admin

# ── Frontend (Angular) environment — set at build time ─────────────────────
# OIDC client ID registered in Zitadel for this app
# Edit: frontend/src/environments/environment.ts
OIDC_CLIENT_ID=CONFIGURE_ME
